{
  "name": "@hy/mac-ui",
  "version": "0.0.1",
  "type": "module",
  "description": "A modern web component library built with Lit",
  "keywords": [
    "web-components",
    "lit",
    "component-library",
    "mac-ui"
  ],
  "license": "MIT",
  "author": "huyang",
  "repository": {
    "type": "git",
    "url": "https://github.com/humuchen/mac-ui"
  },
  "main": "./dist/@hy/mac-ui.cjs.js",
  "module": "./dist/@hy/mac-ui.es.js",
  "unpkg": "./dist/@hy/mac-ui.umd.js",
  "types": "./dist/types/@hy/mac-ui.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/@hy/mac-ui.d.ts",
      "import": "./dist/@hy/mac-ui.es.js",
      "require": "./dist/@hy/mac-ui.cjs.js"
    },
    "./styles/*": "./dist/@hy/styles/*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --project tsconfig.build.json && vite build",
    "build:types": "tsc --project tsconfig.build.json",
    "build:lib": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sb": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@open-wc/testing-helpers": "^3.0.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/web-components": "^8.6.14",
    "@storybook/web-components-vite": "^8.6.14",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "storybook": "^8.6.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
